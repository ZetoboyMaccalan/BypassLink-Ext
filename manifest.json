{
  "manifest_version": 3,
  "name": "SFL Bypass - By Zeto",
  "version": "1.0.0",
  "description": "Bypass sfl.gl shortlinks instantly — no waiting, no ads. [Re-mod boleh, asalkan tidak digunakan untuk tindakan ilegal]",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://sfl.gl/*",
    "https://*.sfl.gl/*",
    "https://app.khaddavi.net/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
